@startuml usecase-admin
title Use Case Diagram — Panel Admin SMPN 3 Ajibarang

left to right direction

skinparam packageStyle rectangle
skinparam DefaultFontName Arial
skinparam TitleFontSize 16
skinparam usecase {
  BackgroundColor #EEF2FF
  BorderColor     #1E3A8A
  FontColor       #1E3A8A
  FontSize        12
}
skinparam actor {
  BackgroundColor #FFF7ED
  BorderColor     #EF7C2A
  FontColor       #92400E
  FontSize        13
}
skinparam note {
  BackgroundColor #FFFBEB
  BorderColor     #FCD34D
  FontSize        11
}
skinparam package {
  BackgroundColor #F9FAFB
  BorderColor     #9CA3AF
}

actor "Admin"                 as Admin
actor "Petugas\nPerpustakaan" as Petugas
actor "Kepala\nSekolah"       as Kepala

rectangle "Panel Admin — SMPN 3 Ajibarang" #FAFAFA {

  '─────────────────────────────────────────────────────────
  '  Autentikasi  (semua aktor)
  '─────────────────────────────────────────────────────────
  usecase "Login ke Panel Admin" as UC_Login

  '─────────────────────────────────────────────────────────
  '  Dasbor
  '─────────────────────────────────────────────────────────
  package "Dasbor" {
    usecase "Lihat Dasbor Sekolah"       as UC_DashSchool
    usecase "Lihat Dasbor Perpustakaan"  as UC_DashLib
  }

  '─────────────────────────────────────────────────────────
  '  Konten Sekolah  [Admin only]
  '─────────────────────────────────────────────────────────
  package "Konten Sekolah  [Admin]" {
    usecase "Kelola Berita & Pengumuman"      as UC_Posts
    usecase "Kelola Galeri Foto"              as UC_Galleries
    usecase "Kelola Video Profil"             as UC_VideoProfiles
    usecase "Kelola Ekstrakurikuler"          as UC_Ekskul
    usecase "Kelola Sambutan\nKepala Sekolah" as UC_Greeting
  }

  '─────────────────────────────────────────────────────────
  '  Profil & Organisasi  [Admin only]
  '─────────────────────────────────────────────────────────
  package "Profil & Organisasi  [Admin]" {
    usecase "Kelola Profil Sekolah"          as UC_Profiles
    usecase "Kelola Guru &\nTenaga Pendidik" as UC_Teachers
    usecase "Kelola Struktur Organisasi"     as UC_OrgStruct
  }

  '─────────────────────────────────────────────────────────
  '  Komunikasi  [Admin only]
  '─────────────────────────────────────────────────────────
  package "Komunikasi  [Admin]" {
    usecase "Baca Pesan Masuk"      as UC_Messages
    usecase "Edit Informasi Kontak" as UC_ContactInfos
    usecase "Kelola Media Sosial"   as UC_SocialMedia
  }

  '─────────────────────────────────────────────────────────
  '  Sistem  [Admin only]
  '─────────────────────────────────────────────────────────
  package "Sistem  [Admin]" {
    usecase "Edit Pengaturan Sistem" as UC_Settings
  }

  '─────────────────────────────────────────────────────────
  '  Sistem Perpustakaan  [Petugas only]
  '─────────────────────────────────────────────────────────
  package "Sistem Perpustakaan  [Petugas]" {
    usecase "Kelola Data Buku"          as UC_Books
    usecase "Kelola Data Anggota"       as UC_Members
    usecase "Catat Peminjaman Buku"     as UC_Loans
    usecase "Proses Pengembalian Buku"  as UC_Returns
    usecase "Update Status Denda"       as UC_Fines
  }

  '─────────────────────────────────────────────────────────
  '  Laporan  [Petugas + Kepala]
  '─────────────────────────────────────────────────────────
  package "Laporan Perpustakaan  [Petugas + Kepala]" {
    usecase "Lihat & Cetak Laporan\nPerpustakaan" as UC_Reports
  }

}

'═══════════════════════════════════════════════════════════
'  Hubungan Aktor → Use Case
'═══════════════════════════════════════════════════════════

'── semua aktor ──────────────────────────────────────────
Admin   --> UC_Login
Petugas --> UC_Login
Kepala  --> UC_Login

'── dasbor per role ──────────────────────────────────────
Admin   --> UC_DashSchool
Petugas --> UC_DashLib
Kepala  --> UC_DashLib

'── Admin: konten sekolah ────────────────────────────────
Admin --> UC_Posts
Admin --> UC_Galleries
Admin --> UC_VideoProfiles
Admin --> UC_Ekskul
Admin --> UC_Greeting

'── Admin: profil & organisasi ───────────────────────────
Admin --> UC_Profiles
Admin --> UC_Teachers
Admin --> UC_OrgStruct

'── Admin: komunikasi ────────────────────────────────────
Admin --> UC_Messages
Admin --> UC_ContactInfos
Admin --> UC_SocialMedia

'── Admin: sistem ────────────────────────────────────────
Admin --> UC_Settings

'── Petugas: perpustakaan ────────────────────────────────
Petugas --> UC_Books
Petugas --> UC_Members
Petugas --> UC_Loans
Petugas --> UC_Returns
Petugas --> UC_Fines

'── Petugas + Kepala: laporan ────────────────────────────
Petugas --> UC_Reports
Kepala  --> UC_Reports

'═══════════════════════════════════════════════════════════
'  Catatan Keterbatasan Operasi
'═══════════════════════════════════════════════════════════

note right of UC_Messages
  Read-only:
  hanya lihat & buka detail;
  tanpa tambah / edit / hapus
  (canCreate/Edit/Delete = false)
end note

note right of UC_ContactInfos
  Edit data existing saja:
  tanpa tambah atau hapus
  (canCreate/Delete = false)
end note

note right of UC_Settings
  Edit konfigurasi saja:
  tanpa hapus
  (canDelete = false)
end note

note right of UC_Returns
  Proses via aksi tabel "Kembalikan"
  (modal tanggal kembali);
  tidak ada halaman Create/Edit
  (canCreate = false)
end note

note right of UC_Fines
  Dibuat otomatis saat pengembalian
  terlambat (Rp 1.000/hari);
  Petugas hanya update status bayar
  & tanggal lunas
  (canCreate = false)
end note

note right of UC_Reports
  Read-only untuk semua role;
  tersedia tombol cetak laporan
  (canCreate/Edit/Delete = false)
end note

@enduml
